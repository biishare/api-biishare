{
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./build",

    "module": "node16",
    "target": "ES2019",
    "moduleResolution": "node16",

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true
  },
  "include": [
    "src/**/*",
    "api/**/*"
  ]
}



